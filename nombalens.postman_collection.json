        {
          "id": "auth-register",
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.success && data.data) {",
                  "  pm.environment.set('accessToken', data.data.accessToken);",
                  "  pm.environment.set('refreshToken', data.data.refreshToken);",
                  "  pm.environment.set('merchantId', data.data.merchant.id);",
                  "  pm.environment.set('subAccountId', data.data.merchant.subAccountId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessName\": \"Test Merchant\",\n  \"phone\": \"0700000001\",\n  \"subAccountId\": \"{{subAccountId}}\",\n  \"pin\": \"1234\"\n}",
              "options": {
                "raw": {
                  "language": "json"
