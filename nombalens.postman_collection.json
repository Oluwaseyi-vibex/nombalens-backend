    {
      "id": "receive-nomba-webhook",
      "name": "Receive Nomba Webhook",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "nomba-timestamp",
            "value": "{{nomba_timestamp}}"
          },
          {
            "key": "nomba-signature",
            "value": "{{nomba_signature}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event_type\": \"payment_success\",\n  \"requestId\": \"req-123\",\n  \"data\": {\n    \"transaction\": {\n      \"transactionId\": \"txn-123\",\n      \"aliasAccountReference\": \"u1\",\n      \"accountNumber\": \"1234567890\",\n      \"transactionAmount\": \"1000\",\n      \"type\": \"credit\",\n      \"responseCode\": \"\",\n      \"time\": \"2026-06-30T12:00:00.000Z\",\n      \"narration\": \"Test payment\"\n    },\n    \"merchant\": {\n      \"userId\": \"u1\",\n      \"walletId\": \"w1\"\n    },\n    \"customer\": {\n      \"senderName\": \"Test User\"\n    }\n  }\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/{{basePath}}/{{apiVersion}}/webhooks/nomba",
          "host": ["{{baseUrl}}"],
          "path": ["{{basePath}}", "{{apiVersion}}", "webhooks", "nomba"]
        },
        "description": "Send a signed Nomba webhook event to the application."
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const secret = pm.environment.get('NOMBA_SECRET_KEY');",
              "if (!secret) {",
              "  throw new Error('NOMBA_SECRET_KEY environment variable is required');",
              "}",
              "const timestamp = Math.floor(Date.now() / 1000).toString();",
              "const body = pm.request.body.raw || '';",
              "const data = JSON.parse(body);",
              "const merchant = data.data?.merchant || {};",
              "const transaction = data.data?.transaction || {};",
              "let transactionResponseCode = transaction.responseCode || '';",
              "if (transactionResponseCode === 'null') {",
              "  transactionResponseCode = '';",
              "}",
              "const hashingPayload = `${data.event_type || ''}:${data.requestId || ''}:${merchant.userId || ''}:${merchant.walletId || ''}:${transaction.transactionId || ''}:${transaction.type || ''}:${transaction.time || ''}:${transactionResponseCode}:${timestamp}`;",
              "const signature = require('crypto').createHmac('sha256', secret).update(hashingPayload).digest('base64');",
              "pm.environment.set('nomba_timestamp', timestamp);",
              "pm.environment.set('nomba_signature', signature);"
            ],
            "type": "text/javascript"
          }
        }
      ]
